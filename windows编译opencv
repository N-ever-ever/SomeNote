message(STATUS "OpenCV Dir: ${OpenCV_DIR}")
message(STATUS "OpenCV Libs: ${OpenCV_LIBS}") # 关键：看这里有没有 dnn
message(STATUS "=================================")



// ❌ 不要这样写（这会隐式依赖所有模块，包括 dnn）
// #include <opencv2/opencv.hpp> 

// ✅ 这样写（只依赖核心和图像处理模块）
#include <opencv2/core.hpp>
#include <opencv2/imgproc.hpp>
#include <opencv2/imgcodecs.hpp> // 如果需要 imread/imwrite



